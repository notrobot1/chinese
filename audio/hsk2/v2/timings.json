[
  {
    "file_name": "0004_63e5ea7m14.mp3",
    "start_time": 0,
    "end_time": 3.213061104000007,
    "text": "孩子 们 玩 的 非常 高兴",
    "translation": "Дети играли очень весело.",
    "pinyin": "Háizi men wán de fēicháng gāoxìng"
  },
  {
    "file_name": "0029_f1fvf26s0o.mp3",
    "start_time": 3.213061104000007,
    "end_time": 5.8775508000000105,
    "text": "那 个 女人 我 认识",
    "translation": "Я знаю ту женщину.",
    "pinyin": "Nà gè nǚrén wǒ rènshi"
  },
  {
    "file_name": "0081_pao3bu4.mp3",
    "start_time": 5.8775508000000105,
    "end_time": 6.97469361600001
  },
  {
    "file_name": "0082_part1s1031.mp3",
    "start_time": 6.97469361600001,
    "end_time": 9.377958832000012,
    "text":"这 条 路 很 长",
    "translation": "Эта дорога очень длинная.",
    "pinyin": "Zhè tiáo lù hěn cháng"
  },
  {
    "file_name": "0083_part1s1046.mp3",
    "start_time": 9.377958832000012,
    "end_time": 12.068570976000014,
    "text": "你 懂 英语 吗",
    "translation": "Ты знаешь английский?",
    "pinyin": "Nǐ dǒng Yīngyǔ ma?"
  },
  {
    "file_name": "0084_part1s1055.mp3",
    "start_time": 12.068570976000014,
    "end_time": 14.497958640000016,
    "text": "我 认为 你 错 了",
    "translation": "Я считаю, что ты ошибся.",
    "pinyin": "Wǒ rènwéi nǐ cuò le"
  },
  {
    "file_name": "0085_part1s1084.mp3",
    "start_time": 14.497958640000016,
    "end_time": 16.848978960000018,
    "text": "一 小时 后 见",
    "translation": "Увидимся через час.",
    "pinyin": "Yī xiǎoshí hòu jiàn"
  },
  {
    "file_name": "0086_part1s111.mp3",
    "start_time": 16.848978960000018,
    "end_time": 19.905305376000022,
    "text": "今天 上午 考试",
    "translation": "Сегодня утром экзамен.",
    "pinyin": "Jīntiān shàngwǔ kǎoshì"

  },
  {
    "file_name": "0087_part1s1169.mp3",
    "start_time": 19.905305376000022,
    "end_time": 22.12571345600002,
    "text": "他 爱 做 运动",
    "translation": "Он любит заниматься спортом.",
    "pinyin": "Tā ài zuò yùndòng"
  },
  {
    "file_name": "0088_part1s125.mp3",
    "start_time": 22.12571345600002,
    "end_time": 25.155917424000027,
    "text": "这 个 房间 是 我 的",
    "translation": "Эта комната моя.",
    "pinyin": "Zhè gè fángjiān shì wǒ de"
  },
  {
    "file_name": "0089_part1s151.mp3",
    "start_time": 25.155917424000027,
    "end_time": 28.264488736000033,
    "text": "请 你 再 说 一 遍",
    "translation": "Пожалуйста, повтори ещё раз.",
    "pinyin": "Qǐng nǐ zài shuō yí biàn"
  },
  {
    "file_name": "0090_part1s156.mp3",
    "start_time": 28.264488736000033,
    "end_time": 31.111835568000036,
    "text": "他 喜欢 帮助 别 人",
    "translation": "Он любит помогать другим.",
    "pinyin": "Tā xǐhuan bāngzhù bié rén" 
  },
  {
    "file_name": "0091_part1s157.mp3",
    "start_time": 31.111835568000036,
    "end_time": 33.90693750400004,
    "text": "他 做 了 自我 介绍",
    "translation": "Он представился / сделал самопредставление.",
    "pinyin": "Tā zuò le zìwǒ jièshào"
  },
  {
    "file_name": "0092_part1s168.mp3",
    "start_time": 33.90693750400004,
    "end_time": 36.571427200000045,
    "text": "病人 需要 休息",
    "translation": "Пациенту нужно отдохнуть.",
    "pinyin": "Bìngrén xūyào xiūxi"
  },
  {
    "file_name": "0093_part1s17.mp3",
    "start_time": 36.571427200000045,
    "end_time": 40.17632502400006,
    "text": "现在 的 气温 是 零 度",
    "translation": "Сейчас температура ноль градусов.",
    "pinyin": "Xiànzài de qìwēn shì líng dù"
  },
  {
    "file_name": "0094_part1s178.mp3",
    "start_time": 40.17632502400006,
    "end_time": 42.396733104000056,
    "text": "我 出去 一 下",
    "translation": "Я ненадолго выйду.",
    "pinyin": "Wǒ chūqù yí xià"
  },
  {
    "file_name": "0095_part1s192.mp3",
    "start_time": 42.396733104000056,
    "end_time": 45.11346769600006,
    "text": "我 家 离 学校 很 近",
    "translation": "Мой дом очень близко к школе.",
    "pinyin": "Wǒ jiā lí xuéxiào hěn jìn"
  },
  {
    "file_name": "0096_part1s279.mp3",
    "start_time": 45.11346769600006,
    "end_time": 47.804079840000064,
    "text": "他 走路 上班",
    "translation": "Он ходит на работу пешком.",
    "pinyin": "Tā zǒulù shàngbān"
  },
  {
    "file_name": "0097_part1s328.mp3",
    "start_time": 47.804079840000064,
    "end_time": 50.57305932800007,
    "text": "我 可以 问 你 一 件 事 吗",
    "translation": "Могу я задать тебе один вопрос?",
    "pinyin": "Wǒ kěyǐ wèn nǐ yí jiàn shì ma"
  },
  {
    "file_name": "0098_part1s348.mp3",
    "start_time": 50.57305932800007,
    "end_time": 53.02856944000007,
    "text": "请 告诉 我 答案",
    "translation": "Пожалуйста, скажи мне ответ.",
    "pinyin": "Qǐng gàosu wǒ dá'àn"
  },
  {
    "file_name": "0099_part1s36.mp3",
    "start_time": 53.02856944000007,
    "end_time": 55.69305913600007,
    "text": "我 也 喜欢 看 书",
    "translation": "Я тоже люблю читать книги.",
    "pinyin": "Wǒ yě xǐhuan kàn shū"
  },
  {
    "file_name": "0100_part1s407.mp3",
    "start_time": 55.69305913600007,
    "end_time": 58.54040596800008,
    "text": "我 把 房子 卖 了",
    "translation": "Я продал дом.",
    "pinyin": "Wǒ bǎ fángzi mài le"
  },
  {
    "file_name": "0101_part1s443.mp3",
    "start_time": 58.54040596800008,
    "end_time": 61.231018112000086,
    "text": "晚上 我 有 事",
    "translation": "Вечером у меня есть дела.",
    "pinyin": "Wǎnshang wǒ yǒu shì"
  },
  {
    "file_name": "0102_part1s477.mp3",
    "start_time": 61.231018112000086,
    "end_time": 64.28734452800009,
    "text": "他 穿 着 红 大衣",
    "translation": "Он одет в красное пальто.",
    "pinyin": "Tā chuān zhe hóng dàyī"
  },
  {
    "file_name": "0103_part1s519.mp3",
    "start_time": 64.28734452800009,
    "end_time": 67.4742831840001,
    "text": "我 很 喜欢 唱歌",
    "translation": "Мне очень нравится петь.",
    "pinyin": "Wǒ hěn xǐhuan chànggē"
    
  },
  {
    "file_name": "0104_part1s532.mp3",
    "start_time": 67.4742831840001,
    "end_time": 69.9820381920001,
    "text": "这 道 菜 很 好吃",
    "translation": "Это блюдо очень вкусное.",
    "pinyin": "Zhè dào cài hěn hǎochī"
  },
  {
    "file_name": "0105_part1s541.mp3",
    "start_time": 69.9820381920001,
    "end_time": 73.79591560000011,
    "text": "我 和 妻子 一起 吃 晚饭",
    "translation": "Я ужинаю вместе с женой.",
    "pinyin": "Wǒ hé qīzi yìqǐ chī wǎnfàn"
  },
  {
    "file_name": "0106_part1s60.mp3",
    "start_time": 73.79591560000011,
    "end_time": 75.83346654400012,
    "text": "我 比 他 高",
    "translation": "Я выше его.",
    "pinyin": "Wǒ bǐ tā gāo"
  },
  {
    "file_name": "0107_part1s61.mp3",
    "start_time": 75.83346654400012,
    "end_time": 79.15101744000013,
    "text": "他 还 是 小 孩子",
    "translation": "Он всё ещё ребёнок.",
    "pinyin": "Tā hái shì xiǎo háizi"
  },
  {
    "file_name": "0108_part1s65.mp3",
    "start_time": 79.15101744000013,
    "end_time": 82.88652750400014,
    "text": "他 说话 说 得 很 大声",
    "translation": "Он говорит очень громко.",
    "pinyin": "Tā shuōhuà shuō de hěn dàshēng"
  },
  {
    "file_name": "0109_part1s727.mp3",
    "start_time": 82.88652750400014,
    "end_time": 85.73387433600014,
    "text": "他 是 我 的 姐姐",
    "translation": "Она моя старшая сестра.",
    "pinyin": "Tā shì wǒ de jiějie"
  },
  {
    "file_name": "0110_part1s765.mp3",
    "start_time": 85.73387433600014,
    "end_time": 88.94693544000015,
    "text": "他 是 这里 服务员",
    "translation": "Он здесь официант.",
    "pinyin": "Tā shì zhèlǐ fúwùyuán"
  },
  {
    "file_name": "0111_part1s850.mp3",
    "start_time": 88.94693544000015,
    "end_time": 92.70856795200015,
    "text": "她 站 在 门口",
    "translation": "Она стоит у дверей.",
    "pinyin": "Tā zhàn zài ménkǒu"
  },
  {
    "file_name": "0112_part1s859.mp3",
    "start_time": 92.70856795200015,
    "end_time": 94.90285358400016,
    "text": "这 是 一 次 事故",
    "translation": "Это происшествие / авария.",
    "pinyin": "Zhè shì yí cì shìgù"
  },
  {
    "file_name": "0113_part1s860.mp3",
    "start_time": 94.90285358400016,
    "end_time": 98.35101672000016,
    "text": "火车 到 站 了",
    "translation": "Поезд прибыл на станцию.",
    "pinyin": "Huǒchē dào zhàn le"
  },
  {
    "file_name": "0114_part1s862.mp3",
    "start_time": 98.35101672000016,
    "end_time": 102.21713902400018,
    "text": "他 一 个 人 在 公司",
    "translation": "Он один в офисе.",
    "pinyin": "Tā yí gè rén zài gōngsī"
  },
  {
    "file_name": "0115_part1s864.mp3",
    "start_time": 102.21713902400018,
    "end_time": 105.50856747200018,
    "text": "他 要 出发 了",
    "translation": "Он собирается отправляться.",
    "pinyin": "Tā yào chūfā le"
  },
  {
    "file_name": "0116_part1s869.mp3",
    "start_time": 105.50856747200018,
    "end_time": 108.06856737600019,
    "text": "这 时候 天 黑 了",
    "translation": "В это время темно.",
    "pinyin": "Zhè shíhou tiān hēi le"
  },
  {
    "file_name": "0117_part1s872.mp3",
    "start_time": 108.06856737600019,
    "end_time": 111.5689754080002,
    "text": "我 还 没 吃 饭",
    "translation": "Я ещё не ел.",
    "pinyin": "Wǒ hái méi chī fàn"
    
  },
  {
    "file_name": "0118_part1s876.mp3",
    "start_time": 111.5689754080002,
    "end_time": 115.4873426080002,
    "text": "我 最 喜欢 看 书",
    "translation": "Я больше всего люблю читать книги.",
    "pinyin": "Wǒ zuì xǐhuan kàn shū"
  },
  {
    "file_name": "0119_part1s877.mp3",
    "start_time": 115.4873426080002,
    "end_time": 117.7861180320002,
    "text": "汽车 出 问题 了",
    "translation": "С машиной возникла проблема.",
    "pinyin": "Qìchē chū wèntí le"
  },
  {
    "file_name": "0120_part1s89.mp3",
    "start_time": 117.7861180320002,
    "end_time": 120.58121996800021,
    "text": "他 写字 很 快",
    "translation": "Он пишет очень быстро.",
    "pinyin": "Tā xiězì hěn kuài"
  },
  {
    "file_name": "0121_part1s908.mp3",
    "start_time": 120.58121996800021,
    "end_time": 124.26448513600022,
    "text": "水 喝 完 了",
    "translation": "Вода закончилась.",
    "pinyin": "Shuǐ hē wán le"
  },
  {
    "file_name": "0122_part1s913.mp3",
    "start_time": 124.26448513600022,
    "end_time": 128.60081150400023,
    "text": "雨 很 大 但是 他 也 还是 出门 了",
    "translation": "Сильный дождь, но он всё равно вышел.",
    "pinyin": "Yǔ hěn dà dànshì tā yě háishì chūmén le"
  },
  {
    "file_name": "0123_part1s915.mp3",
    "start_time": 128.60081150400023,
    "end_time": 132.33632156800024,
    "text": "因为 我 病 了 所以 没 去 上学",
    "translation": "Потому что я был болен, я не пошёл в школу.",
    "pinyin": "Yīnwèi wǒ bìng le suǒyǐ méi qù shàngxué"
  },
  {
    "file_name": "0124_part1s950.mp3",
    "start_time": 132.33632156800024,
    "end_time": 136.85550507200026,
    "text": "时间 很 晚 了 我们 回 家 吧",
    "translation": "Уже очень поздно, давай пойдём домой.",
    "pinyin": "Shíjiān hěn wǎn le wǒmen huí jiā ba"
  },
  {
    "file_name": "0125_part1s959.mp3",
    "start_time": 136.85550507200026,
    "end_time": 139.04979070400026,
    "text": "请 往 左 拐",
    "translation": "Пожалуйста, поверните налево.",
    "pinyin": "Qǐng wǎng zuǒ guǎi"
  },
  {
    "file_name": "0126_part1s990.mp3",
    "start_time": 139.04979070400026,
    "end_time": 143.07264769600027,
    "text": "我 希望 明天 不 下雨",
    "translation": "Я надеюсь, что завтра не будет дождя.",
    "pinyin": "Wǒ xīwàng míngtiān bù xiàyǔ"
  },
  {
    "file_name": "0127_part1s991.mp3",
    "start_time": 143.07264769600027,
    "end_time": 145.58040270400028,
    "text": "他 已经 准备 好 了",
    "translation": "Он уже готов.",
    "pinyin": "Tā yǐjīng zhǔnbèi hǎo le"
  },
  {
    "file_name": "0128_part1s992.mp3",
    "start_time": 145.58040270400028,
    "end_time": 148.76734136000027,
    "text": "他 可能 在 教室 里",
    "pinyin": "tā kě néng zài jiào shì lǐ",
    "translation": "Он может быть в классе"
  },
  {
    "file_name": "0129_part2s1160.mp3",
    "start_time": 148.76734136000027,
    "end_time": 153.18203507200028,
    "text": "今年 玉米种 的 价格比 去年 偏高",
    "pinyin": "jīn nián yù mǐ zhǒng de jià gé bǐ qù nián piān gāo",
    "translation": "Цена на семена кукурузы в этом году выше, чем в прошлом году"
  },
  {
    "file_name": "0130_part2s1238.mp3",
    "start_time": 153.18203507200028,
    "end_time": 155.82040232000028,
    "text": "要 开始 起 作用 了",
    "pinyin": "yào kāi shǐ qǐ zuò yòng le",
    "translation": "Скоро начнет работать"
  },
  {
    "file_name": "0131_part2s1245.mp3",
    "start_time": 155.82040232000028,
    "end_time": 158.6155042560003,
    "text": "我 打算 出国 旅游",
    "pinyin": "wǒ dǎ suàn chū guó lǚ yóu",
    "translation": "Я планирую поехать за границу"
  },
  {
    "file_name": "0132_part2s1969.mp3",
    "start_time": 158.6155042560003,
    "end_time": 161.9853000480003,
    "text": "今天 早上 天气 不错",
    "pinyin": "jīn tiān zǎo shàng tiān qì bù cuò",
    "translation": "Погода сегодня хорошая"
  },
  {
    "file_name": "0133_part2s26.mp3",
    "start_time": 161.9853000480003,
    "end_time": 164.17958568000032,
    "text": "还有 其他 事情 吗 ?",
    "pinyin": "hái yǒu qí tā shì qíng ma ?",
    "translation": "Что-нибудь еще?"
  },
  {
    "file_name": "0134_part2s319.mp3",
    "start_time": 164.17958568000032,
    "end_time": 167.39264678400033,
    "text": "您 喜欢 吃 羊肉 吗 ?",
    "pinyin": "nín xǐ huān chī yáng ròu ma ?",
    "translation": "Вы любите есть баранину?"
  },
  {
    "file_name": "0135_part2s9.mp3",
    "start_time": 167.39264678400033,
    "end_time": 169.90040179200034,
    "text": "我 每天 都 刷牙",
    "pinyin": "wǒ měi tiān dōu shuā yá",
    "translation": "Я чищу зубы каждый день"
  },
  {
    "file_name": "0146_sapi5-7332448e-76f67aa9-aa6c8c3a-7a5e5c44-49843e01.mp3",
    "start_time": 169.90040179200034,
    "end_time": 172.19917721600035,
    "text": "服务员 我要 一 碗 面条",
    "pinyin": "fú wù yuán , wǒ yào yī wǎn miàn tiáo",
    "translation": "Официант, я хочу тарелку лапши."
  },
  {
    "file_name": "0162_tmp0kw861.mp3",
    "start_time": 172.19917721600035,
    "end_time": 174.86366691200035,
    "text": "我 钓到 一条 鱼",
    "pinyin": "wǒ diào dào yī tiáo yú",
    "translation": "я поймал рыбу"
  },
  {
    "file_name": "0163_tmp1bivca.mp3",
    "start_time": 174.86366691200035,
    "end_time": 178.10285046400037,
    "text": "让 我 来 回答 这个 问题",
    "pinyin": "ràng wǒ lái huí dá zhè ge wèn tí",
    "translation": "позвольте мне ответить на этот вопрос"
  },
  {
    "file_name": "0164_tmp1eldcw.mp3",
    "start_time": 178.10285046400037,
    "end_time": 181.9167278720004,
    "text": "孩子 们 爱 吃 西瓜",
    "pinyin": "hái zi men ài chī xī guā",
    "translation": "Дети любят есть арбуз"
  },
  {
    "file_name": "0165_tmp2iciuh.mp3",
    "start_time": 181.9167278720004,
    "end_time": 184.0065237120004,
    "text": "鸡蛋 破 了",
    "pinyin": "jī dàn pò le",
    "translation": "Яйцо разбито"
  },
  {
    "file_name": "0166_tmp2spnti.mp3",
    "start_time": 184.0065237120004,
    "end_time": 185.91346241600039,
    "text": "你 做 对 了",
    "pinyin": "nǐ zuò duì le",
    "translation": "ты сделал правильную вещь"
  },
  {
    "file_name": "0167_tmp3xx9pe.mp3",
    "start_time": 185.91346241600039,
    "end_time": 188.8652990400004,
    "text": "附近 有 公共 汽车 站",
    "pinyin": "fù jìn yǒu gōng gòng qì chē zhàn",
    "translation": "Рядом находится автобусная остановка"
  },
  {
    "file_name": "0168_tmp6ztpbn.mp3",
    "start_time": 188.8652990400004,
    "end_time": 191.0857071200004,
    "text": "他 觉得 很累",
    "pinyin": "tā jué de hěn lèi",
    "translation": "он чувствует себя очень уставшим"
  },
  {
    "file_name": "0169_tmp7rl0if.mp3",
    "start_time": 191.0857071200004,
    "end_time": 194.7167273920004,
    "text": "花园 中 有 一個 游泳池",
    "pinyin": "huā yuán zhōng yǒu yī gè yóu yǒng chí",
    "translation": "В саду есть бассейн"
  },
  {
    "file_name": "0170_tmp8hb7ui.mp3",
    "start_time": 194.7167273920004,
    "end_time": 198.2171354240004,
    "text": "其中 的 高个子 就是 我 哥哥",
    "pinyin": "qí zhōng de gāo gè zi jiù shì wǒ gē gē",
    "translation": "Высокий парень среди них - мой брат"
  },
  {
    "file_name": "0171_tmp8vkdtb.mp3",
    "start_time": 198.2171354240004,
    "end_time": 201.6652985600004,
    "text": "吃饭 前要 洗手",
    "pinyin": "chī fàn qián yào xǐ shǒu",
    "translation": "Мойте руки перед едой"
  },
  {
    "file_name": "0172_tmpahfgpd.mp3",
    "start_time": 201.6652985600004,
    "end_time": 204.5648902880004,
    "text": "今天 是 我 的 生日",
    "pinyin": "jīn tiān shì wǒ de shēng rì",
    "translation": "сегодня мой день рождения"
  },
  {
    "file_name": "0173_tmpak46ds.mp3",
    "start_time": 204.5648902880004,
    "end_time": 207.85631873600042,
    "text": "这件 衣服 多少 钱 ?",
    "pinyin": "zhè jiàn yī fú duō shǎo qián ?",
    "translation": "Сколько стоит это платье?"
  },
  {
    "file_name": "0174_tmpbamvhc.mp3",
    "start_time": 207.85631873600042,
    "end_time": 211.95754307200042,
    "text": "她 跳舞 时 的 姿态 很 美",
    "pinyin": "tā tiào wǔ shí de zī tài hěn měi",
    "translation": "Ее поза во время танца прекрасна"
  },
  {
    "file_name": "0175_tmpbmz6aq.mp3",
    "start_time": 211.95754307200042,
    "end_time": 215.32733886400044,
    "text": "大家 坐在 桌子 旁边",
    "pinyin": "dà jiā zuò zài zhuō zi páng biān",
    "translation": "Все сидят вокруг стола"
  },
  {
    "file_name": "0176_tmpbpxy6m.mp3",
    "start_time": 215.32733886400044,
    "end_time": 218.87999179200045,
    "text": "学校 离 我家 很 远",
    "pinyin": "xué xiào lí wǒ jiā hěn yuǎn",
    "translation": "Школа находится далеко от моего дома"
  },
  {
    "file_name": "0177_tmpbtfbgh.mp3",
    "start_time": 218.87999179200045,
    "end_time": 222.32815492800046,
    "text": "这 部手机 可以 拨打 国际 电话",
    "pinyin": "zhè bù shǒu jī kě yǐ bō dǎ guó jì diàn huà",
    "translation": "Этот телефон может совершать международные звонки"
  },
  {
    "file_name": "0178_tmpdag6hd.mp3",
    "start_time": 222.32815492800046,
    "end_time": 224.57468545600045,
    "text": "已经 5 点 了",
    "pinyin": "yǐ jīng 5 diǎn le",
    "translation": "Уже 5 часов"
  },
  {
    "file_name": "0179_tmpdcyfcn.mp3",
    "start_time": 224.57468545600045,
    "end_time": 228.07509348800045,
    "text": "这 间 宾馆 非常 豪华",
    "pinyin": "zhè jiān bīn guǎn fēi cháng háo huá",
    "translation": "Этот отель очень роскошный"
  },
  {
    "file_name": "0180_tmpdsyqy_.mp3",
    "start_time": 228.07509348800045,
    "end_time": 230.73958318400045,
    "text": "桌子 上 有 一杯 咖啡",
    "pinyin": "zhuō zi shàng yǒu yī bēi kā fēi",
    "translation": "На столе стоит чашка кофе"
  },
  {
    "file_name": "0181_tmpf7kv8v.mp3",
    "start_time": 230.73958318400045,
    "end_time": 232.93386881600046,
    "text": "他 是 我 的 弟弟",
    "pinyin": "tā shì wǒ de dì di",
    "translation": "он мой брат"
  },
  {
    "file_name": "0182_tmpf9vo9l.mp3",
    "start_time": 232.93386881600046,
    "end_time": 235.59835851200046,
    "text": "大家 在 吃 午饭",
    "pinyin": "dà jiā zài chī wǔ fàn",
    "translation": "Все обедают"
  },
  {
    "file_name": "0183_tmpfb9q_g.mp3",
    "start_time": 235.59835851200046,
    "end_time": 238.31509310400045
  },
  {
    "file_name": "0184_tmpgbhzfs.mp3",
    "start_time": 238.31509310400045,
    "end_time": 241.16243993600045,
    "text": "请 出示 您 的 护照",
    "pinyin": "qǐng chū shì nín de hù zhào",
    "translation": "пожалуйста, покажите свой паспорт"
  },
  {
    "file_name": "0185_tmpgewani.mp3",
    "start_time": 241.16243993600045,
    "end_time": 245.02856224000047,
    "text": "我 从 昨天 开始 戒烟",
    "pinyin": "wǒ cóng zuó tiān kāi shǐ jiè yān",
    "translation": "Я вчера начал бросать курить"
  },
  {
    "file_name": "0186_tmpgmnfo3.mp3",
    "start_time": 245.02856224000047,
    "end_time": 248.31999068800047,
    "text": "这件 衣服 很 便宜",
    "pinyin": "zhè jiàn yī fú hěn pián yi",
    "translation": "Это платье очень дешевое"
  },
  {
    "file_name": "0187_tmpgyisb6.mp3",
    "start_time": 248.31999068800047,
    "end_time": 251.66366403200047
    
  },
  {
    "file_name": "0188_tmph09oyz.mp3",
    "start_time": 251.66366403200047,
    "end_time": 253.96243945600048,
    "text": "他 是 我 的 丈夫",
    "pinyin": "tā shì wǒ de zhàng fū",
    "translation": "он мой муж"
  },
  {
    "file_name": "0189_tmphd4yrq.mp3",
    "start_time": 253.96243945600048,
    "end_time": 256.4963169120005,
    "text": "我们 正在 开会",
    "pinyin": "wǒ men zhèng zài kāi huì",
    "translation": "у нас встреча"
  },
  {
    "file_name": "0190_tmphn9m5s.mp3",
    "start_time": 256.4963169120005,
    "end_time": 260.64978614400053,
    "text": "男朋友 同 我 一起 去 旅行",
    "pinyin": "nán péng yǒu tóng wǒ yì qǐ qù lǚ xíng",
    "translation": "Мой парень путешествует со мной"
  },
  {
    "file_name": "0191_tmphnjfbf.mp3",
    "start_time": 260.64978614400053,
    "end_time": 263.2097860480005,
    "text": "他 在 拆卸 手表",
    "pinyin": "tā zài chāi xiè shǒu biǎo",
    "translation": "Он разбирает часы"
  },
  {
    "file_name": "0192_tmphun9kp.mp3",
    "start_time": 263.2097860480005,
    "end_time": 266.1355002240005,
    "text": "别 担心",
    "pinyin": "bié dān xīn",
    "translation": "Не волнуйтесь"
  },
  {
    "file_name": "0193_tmphvn8sf.mp3",
    "start_time": 266.1355002240005,
    "end_time": 269.6881531520005,
    "text": "我 有 一千 美金",
    "pinyin": "wǒ yǒu yī qiān měi jīn",
    "translation": "У меня есть тысяча долларов"
  },
  {
    "file_name": "0194_tmphypvb9.mp3",
    "start_time": 269.6881531520005,
    "end_time": 272.6399897760005,
    "text": "他们 在 踢足球",
    "pinyin": "tā men zài tī zú qiú",
    "translation": "они играют в футбол"
  },
  {
    "file_name": "0195_tmpiegtgj.mp3",
    "start_time": 272.6399897760005,
    "end_time": 277.4203977600005,
    "text": "这里 有 很多 彩色 铅笔",
    "pinyin": "zhè lǐ yǒu hěn duō cǎi sè qiān bǐ",
    "translation": "Здесь много цветных карандашей"
  },
  {
    "file_name": "0196_tmpifrz_h.mp3",
    "start_time": 277.4203977600005,
    "end_time": 280.0848874560005,
    "text": "大家 在 等 公车",
    "pinyin": "dà jiā zài děng gōng chē",
    "translation": "Все ждут автобус"
  },
  {
    "file_name": "0197_tmpioxozi.mp3",
    "start_time": 280.0848874560005,
    "end_time": 283.1673363200005,
    "text": "飞机 抵达 了 机场",
    "pinyin": "fēi jī dǐ dá le jī chǎng",
    "translation": "Самолет прибыл в аэропорт"
  },
  {
    "file_name": "0198_tmpjdgif8.mp3",
    "start_time": 283.1673363200005,
    "end_time": 285.5444790880005,
    "text": "它 是 我 的 猫",
    "pinyin": "tā shì wǒ de māo",
    "translation": "это мой кот"
  },
  {
    "file_name": "0199_tmpjw7qin.mp3",
    "start_time": 285.5444790880005,
    "end_time": 288.39182592000054,
    "text": "我 不 知道 这件 事",
    "pinyin": "wǒ bù zhī dào zhè jiàn shì",
    "translation": "Я не знаю об этом"
  },
  {
    "file_name": "0200_tmpknpe29.mp3",
    "start_time": 288.39182592000054,
    "end_time": 292.85876452800056,
    "text": "他们 跑步 的 速度 很 平均",
    "pinyin": "tā men pǎo bù de sù dù hěn píng jūn",
    "translation": "Скорость бега у них средняя."
  },
  {
    "file_name": "0201_tmpktnvid.mp3",
    "start_time": 292.85876452800056,
    "end_time": 295.34039708800054,
    "text": "他们 走 得 很慢",
    "pinyin": "tā men zǒu dé hěn màn",
    "translation": "они ходят очень медленно"
  },
  {
    "file_name": "0202_tmpkv_ryo.mp3",
    "start_time": 295.34039708800054,
    "end_time": 298.65794798400054,
    "text": "我 去 图书馆 找 资料",
    "pinyin": "wǒ qù tú shū guǎn zhǎo zī liào",
    "translation": "Я иду в библиотеку, чтобы найти информацию"
  },
  {
    "file_name": "0203_tmpl9feqn.mp3",
    "start_time": 298.65794798400054,
    "end_time": 301.08733564800053,
    "text": "或 从 美国 来",
    "pinyin": "huò cóng měi guó lái",
    "translation": "или из США"
  },
  {
    "file_name": "0204_tmpltl2eq.mp3",
    "start_time": 301.08733564800053,
    "end_time": 305.42366201600055,
    "text": "老师 给 孩子 们 上 了 一 堂 课",
    "pinyin": "lǎo shī gěi hái zi men shàng le yī táng kè",
    "translation": "Учитель преподал детям урок"
  },
  {
    "file_name": "0205_tmpmdhevd.mp3",
    "start_time": 305.42366201600055,
    "end_time": 309.31590676800056,
    "text": "一 人 在 花丛 中笑",
    "pinyin": "yī rén zài huā cóng zhōng xiào",
    "translation": "Человек смеётся среди цветов."
  },
  {
    "file_name": "0206_tmpmf3kgg.mp3",
    "start_time": 309.31590676800056,
    "end_time": 312.3461107360006,
    "text": "你们 明白 我 的 意思 了 吗 ?",
    "pinyin": "nǐ men míng bái wǒ de yì si le ma ?",
    "translation": "Вы понимаете, что я имею в виду?"
  },
  {
    "file_name": "0207_tmpmwmxhf.mp3",
    "start_time": 312.3461107360006,
    "end_time": 314.07019230400056,
    "text": "为 什么",
    "pinyin": "wèi shén me",
    "translation": "Почему"
  },
  {
    "file_name": "0208_tmpnvc7pv.mp3",
    "start_time": 314.07019230400056,
    "end_time": 316.83917179200057,
    "text": "他们 穿着 相同 的 衣服",
    "pinyin": "tā men chuān zhe xiāng tóng de yī fú",
    "translation": "они носят одинаковую одежду"
  },
  {
    "file_name": "0209_tmpnzgf9r.mp3",
    "start_time": 316.83917179200057,
    "end_time": 320.20896758400056,
    "text": "假如 天晴 了 我 就 和 你 去 爬山",
    "pinyin": "jiǎ rú tiān qíng le   wǒ jiù hé nǐ qù pá shān",
    "translation": "Если будет солнечно, я пойду с тобой в поход"
  },
  {
    "file_name": "0210_tmpo1xsja.mp3",
    "start_time": 320.20896758400056,
    "end_time": 323.21304910400056,
    "text": "海边 的 风景 真 美",
    "pinyin": "hǎi biān de fēng jǐng zhēn měi",
    "translation": "Пейзажи на берегу моря такие красивые"
  },
  {
    "file_name": "0211_tmpogesne.mp3",
    "start_time": 323.21304910400056,
    "end_time": 325.4857020800006,
    "text": "新 年 快乐",
    "pinyin": "xīn nián kuài lè",
    "translation": "С Новым Годом!"
  },
  {
    "file_name": "0212_tmpouakso.mp3",
    "start_time": 325.4857020800006,
    "end_time": 329.16896724800057,
    "text": "他 为了 健康 锻炼 身体",
    "pinyin": "tā wèi le jiàn kāng duàn liàn shēn tǐ",
    "translation": "Он занимается спортом для здоровья"
  },
  {
    "file_name": "0213_tmpqbsfnw.mp3",
    "start_time": 329.16896724800057,
    "end_time": 331.1281508480006,
    "text": "您 贵姓",
    "pinyin": "nín guì xìng",
    "translation": "Как ваша фамилия?"
  },
  {
    "file_name": "0214_tmpqcwvj8.mp3",
    "start_time": 331.1281508480006,
    "end_time": 333.7665180960006,
    "text": "请 給 我 一 杯 酒",
    "pinyin": "qǐng gěi wǒ yī bēi jiǔ",
    "translation": "Дайте мне, пожалуйста, бокал вина"
  },
  {
    "file_name": "0215_tmpqhv20w.mp3",
    "start_time": 333.7665180960006,
    "end_time": 336.7183547200006,
    "text": "这道 数学 题 很 难",
    "pinyin": "zhè dào shù xué tí hěn nán",
    "translation": "Эта математическая задача сложна"
  },
  {
    "file_name": "0216_tmprc69sw.mp3",
    "start_time": 336.7183547200006,
    "end_time": 339.1738648320006,
    "text": "屋外 下 着 雪",
    "pinyin": "wū wài xià zhe xuě",
    "translation": "На улице идет снег"
  },
  {
    "file_name": "0217_tmprh8qgp.mp3",
    "start_time": 339.1738648320006,
    "end_time": 341.70774228800065,
    "text": "我 有 两 张 门票",
    "pinyin": "wǒ yǒu liǎng zhāng mén piào",
    "translation": "У меня есть два билета"
  },
  {
    "file_name": "0218_tmpriwxfg.mp3",
    "start_time": 341.70774228800065,
    "end_time": 344.5028442240006,
    "text": "要是 你 不 来 我 就 跟 你 分手",
    "pinyin": "yào shì nǐ bù lái , wǒ jiù gēn nǐ fēn shǒu",
    "translation": "Если ты не придешь, я расстанусь с тобой"
  },
  {
    "file_name": "0219_tmprjnw76.mp3",
    "start_time": 344.5028442240006,
    "end_time": 347.01059923200063,
    "text": "天气 陰沉",
    "pinyin": "tiān qì yīn chén",
    "translation": "Погода мрачная"
  },
  {
    "file_name": "0220_tmprxdbdx.mp3",
    "start_time": 347.01059923200063,
    "end_time": 350.27590523200064,
    "text": "外面 在 下雨",
    "pinyin": "wài miàn zài xià yǔ",
    "translation": "На улице дождь"
  },
  {
    "file_name": "0221_tmpsa4ppj.mp3",
    "start_time": 350.27590523200064,
    "end_time": 352.2612112800006,
    "text": "他 生病 了",
    "pinyin": "tā shēng bìng le",
    "translation": "он болен"
  },
  {
    "file_name": "0222_tmpsma4zd.mp3",
    "start_time": 352.2612112800006,
    "end_time": 354.89957852800063,
    "text": "我 有 一 百 块钱",
    "pinyin": "wǒ yǒu 100 kuài qián",
    "translation": "у меня есть 100 юаней"
  },
  {
    "file_name": "0223_tmpsr2ill.mp3",
    "start_time": 354.89957852800063,
    "end_time": 358.03427228800064,
    "text": "在 火车 站 转车",
    "pinyin": "zài huǒ chē zhàn zhuǎn chē",
    "translation": "Трансфер на вокзале"
  },
  {
    "file_name": "0224_tmptb3qec.mp3",
    "start_time": 358.03427228800064,
    "end_time": 360.98610891200065,
    "text": "这是 男 厕所",
    "pinyin": "zhè shì nán cè suǒ",
    "translation": "Это мужской туалет"
  },
  {
    "file_name": "0225_tmptm6hfp.mp3",
    "start_time": 360.98610891200065,
    "end_time": 363.7812108480006,
    "text": "手指甲 太长 了",
    "pinyin": "shǒu zhǐ jiǎ tài zhǎng le",
    "translation": "Ногти слишком длинные"
  },
  {
    "file_name": "0226_tmptrzn2b.mp3",
    "start_time": 363.7812108480006,
    "end_time": 367.07263929600066,
    "text": "右边 这位 是 邓 先生",
    "pinyin": "yòu biān zhè wèi shì dèng xiān shēng",
    "translation": "Это г-н Дэн справа"
  },
  {
    "file_name": "0227_tmpttq4ec.mp3",
    "start_time": 367.07263929600066,
    "end_time": 370.02447592000067,
    "text": "他 在 看 报纸 的 最新 消息",
    "pinyin": "tā zài kàn bào zhǐ de zuì xīn xiāo xī",
    "translation": "Он читает последние новости в газете"
  },
  {
    "file_name": "0228_tmpu5v_op.mp3",
    "start_time": 370.02447592000067,
    "end_time": 375.4318226560007,
    "text": "雖然 跑 得 很 累 但是 很多 人 都 沒 有 放棄",
    "pinyin": "suī rán pǎo dé hěn lèi , dàn shì hěn duō rén dōu méi yǒu fàng qì",
    "translation": "Хотя они устали от бега, многие люди не сдавались."
  },
  {
